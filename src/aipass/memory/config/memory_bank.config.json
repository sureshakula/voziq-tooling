{
  "rollover": {
    "defaults": {
      "max_lines": 600,
      "buffer": 100
    },
    "per_branch": {}
  },
  "memory_pool": {
    "enabled": true,
    "path": "memory_pool",
    "supported_extensions": [".md", ".txt"],
    "collection_name": "memory_pool_docs",
    "keep_recent": 50,
    "archive_path": "memory_pool_archive"
  },
  "plans": {
    "enabled": true,
    "path": "src/aipass/flow/processed_plans",
    "supported_extensions": [".md"],
    "collection_name": "flow_plans"
  }
}
