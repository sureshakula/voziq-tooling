{
  "document_metadata": {
    "document_type": "session_history",
    "document_name": "{{BRANCHNAME}}.LOCAL",
    "version": "2.0.0",
    "schema_version": "2.0.0",
    "created": "{{DATE}}",
    "last_updated": "{{DATE}}",
    "managed_by": "{{BRANCHNAME}}",
    "tags": [
      "session_tracking",
      "work_log",
      "{{BRANCHNAME}}"
    ],
    "limits": {
      "max_sessions": 20,
      "max_key_learnings": 25,
      "max_todos": 10,
