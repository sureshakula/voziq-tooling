      "health": "healthy",
      "last_health_check": "{{DATE}}",
      "current_lines": 0
    }
  },
  "key_learnings": {},
  "todos": [],
  "sessions": [
    {
      "session_number": 1,
      "date": "{{DATE}}",
      "summary": "Branch initialized - {{BRANCHNAME}} created by aipass init.",
      "status": "completed"
    }
  ]
}
