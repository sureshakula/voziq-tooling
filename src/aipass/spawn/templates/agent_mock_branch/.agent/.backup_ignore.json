  "notes": {
    "how_it_works": "Two types of exclusions during backup creation:",
    "ignore_directories": {
      "description": "Directory names to skip entirely (including all contents)",
      "purpose": "Exclude large dependency dirs, caches, and backup dirs themselves",
      "examples": [
        ".venv, venv (Python virtual environments - large, regeneratable)",
        "node_modules (NPM dependencies - huge, regeneratable)",
        "__pycache__, .cache (Python/system caches - regeneratable)",
        ".git (Git repository - already versioned)",
        ".backup, backups (backup directories - prevent recursion)"
      ]
    },
    "ignore_patterns": {
      "description": "Glob patterns for files to skip",
      "purpose": "Exclude temporary files, compiled bytecode, OS cruft",
      "examples": [
        "*.pyc, *.pyo (Python compiled bytecode - regeneratable)",
        "*.log (Log files - can be large, temporary)",
        "*.tmp, *.swp (Temporary/swap files)",
        ".DS_Store, Thumbs.db (OS metadata files)"
      ]
    },
    "customization": "Edit this file in the template to add more patterns. Changes take effect on next branch update.",
    "performance": "Ignoring large directories dramatically speeds up backups (seconds vs minutes for branches with node_modules or .venv)"
  }
}
