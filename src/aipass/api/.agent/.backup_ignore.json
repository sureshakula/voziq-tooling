{
  "metadata": {
    "version": "1.0.0",
    "description": "Files and patterns to exclude when creating branch backups"
  },
  "ignore_directories": [
    ".backup",
    ".venv",
    "venv",
    "node_modules",
    "__pycache__",
    ".git",
    ".cache",
    ".pytest_cache",
    ".mypy_cache",
    "dist",
    "build",
    "*.egg-info",
    "ai_mail.local",
    "logs",
    ".aipass",
    ".archive",
    ".claude",
    "htmlcov"
  ],
  "ignore_patterns": [
    "*.pyc",
    "*.pyo",
    ".DS_Store",
    "*.log",
    "*.tmp",
    "*.swp",
    "*~",
    "*.env",
    "BRANCH_REGISTRY.json"
  ]
}
