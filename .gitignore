!src/aipass/spawn/templates/aipass_framework/.spawn/
!src/aipass/spawn/templates/aipass_framework/.spawn/**
!src/aipass/spawn/templates/aipass_framework/.claude/
!src/aipass/spawn/templates/aipass_framework/.claude/**
!src/aipass/spawn/templates/aipass_framework/*_json/
!src/aipass/spawn/templates/aipass_framework/*_json/**
!src/aipass/spawn/templates/aipass_framework/logs/
!src/aipass/spawn/templates/aipass_framework/logs/**
